# Production Environment Variables
SERVER_PORT=8080
DATABASE_URL=postgres://users:rahasia@localhost:5432/neosim_go_prod_db?sslmode=require
JWT_SECRET=your_prod_jwt_secret_key_here
LOG_LEVEL=info
